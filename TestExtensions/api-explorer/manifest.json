{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "3.0.0",
  "description": "__MSG_appDesc__",
  "default_locale": "en",
  "permissions": ["storage", "tabs", "scripting", "webNavigation", "contextMenus", "offscreen", "alarms", "fontSettings", "idle", "notifications", "history", "bookmarks", "sessions", "search"],
  "host_permissions": ["<all_urls>"],
  "optional_permissions": ["cookies"],
  "commands": {
    "test-command": {
      "suggested_key": {"default": "Alt+Shift+E", "mac": "Alt+Shift+E"},
      "description": "Test API Explorer command"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png",
    "default_title": "API Explorer"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "48": "icon.png"
  }
}
